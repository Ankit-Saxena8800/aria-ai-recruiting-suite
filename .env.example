# Anthropic API (Required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server Configuration
NODE_ENV=production
DASHBOARD_PORT=3001

# JWT Security (Change in production!)
JWT_SECRET=change_this_to_a_random_secure_string
JWT_EXPIRES_IN=24h

# Email Configuration (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-here
EMAIL_FROM=Aria AI <hr@stage.in>

# Application URL (Update with your Vercel URL)
APP_URL=https://your-vercel-app.vercel.app

# Zoho Recruit API (Optional)
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token

# Naukri API (Optional)
NAUKRI_API_KEY=your_naukri_api_key
NAUKRI_ACCOUNT_ID=your_naukri_account_id
