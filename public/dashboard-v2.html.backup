<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>STAGE - Hiring Dashboard | Aria AI</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
            background: linear-gradient(135deg, #0f1419 0%, #1a1f3a 50%, #2d3561 100%);
            color: #333;
            padding: 0;
            min-height: 100vh;
            position: relative;
            overflow-x: hidden;
        }

        body::before {
            content: '';
            position: fixed;
            top: -50%;
            right: -20%;
            width: 80%;
            height: 80%;
            background: radial-gradient(circle, rgba(239, 167, 63, 0.15) 0%, transparent 70%);
            border-radius: 50%;
            animation: float 20s ease-in-out infinite;
            z-index: 0;
        }

        body::after {
            content: '';
            position: fixed;
            bottom: -30%;
            left: -20%;
            width: 70%;
            height: 70%;
            background: radial-gradient(circle, rgba(37, 141, 88, 0.12) 0%, transparent 70%);
            border-radius: 50%;
            animation: floatReverse 25s ease-in-out infinite;
            z-index: 0;
        }

        @keyframes float {
            0%, 100% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(-30px, 30px) scale(1.1); }
        }

        @keyframes floatReverse {
            0%, 100% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(30px, -30px) scale(1.05); }
        }

        .navbar {
            background: #1A1A1A;
            color: #e6e9f0;
            padding: 20px 40px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .navbar-brand {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .logo-container {
            background: white;
            padding: 8px 16px;
            border-radius: 8px;
            font-weight: 800;
            font-size: 1.5em;
            color: #EFA73F;
            letter-spacing: 2px;
        }

        .navbar-title {
            font-size: 1.3em;
            font-weight: 600;
            background: linear-gradient(135deg, #EFA73F 0%, #f4c15d 25%, #EFA73F 50%, #258D58 75%, #2ea76a 100%);
            background-size: 200% auto;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: gradientShift 8s ease infinite;
        }

        @keyframes gradientShift {
            0%, 100% { background-position: 0% center; }
            50% { background-position: 100% center; }
        }

        .navbar-subtitle {
            font-size: 0.85em;
            opacity: 0.9;
        }

        .navbar-info {
            text-align: right;
            display: flex;
            gap: 20px;
            align-items: center;
        }

        .back-btn {
            background: linear-gradient(135deg, #EFA73F 0%, #258D58 100%);
            color: #e6e9f0;
            padding: 10px 20px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 0.95em;
        }

        .back-btn:hover {
            transform: translateX(-5px);
            box-shadow: 0 5px 15px rgba(239, 167, 63, 0.4);
        }

        .last-updated {
            font-size: 0.85em;
            opacity: 0.9;
        }

        .live-indicator {
            display: inline-block;
            width: 8px;
            height: 8px;
            background: #4ade80;
            border-radius: 50%;
            margin-right: 5px;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        .container {
            max-width: 1600px;
            margin: 0 auto;
            padding: 30px;
            position: relative;
            z-index: 1;
        }

        .metrics-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .metric-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px);
            padding: 30px;
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.08);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
            animation: fadeInUp 0.6s ease-out;
            animation-fill-mode: both;
        }

        .metric-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #258D58, #764ba2);
        }

        .metric-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 24px 72px rgba(239, 167, 63, 0.25);
            border-color: rgba(239, 167, 63, 0.2);
        }

        .metric-card .label {
            font-size: 0.85em;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 15px;
            font-weight: 600;
        }

        .metric-card .value {
            font-size: 3em;
            font-weight: 800;
            background: linear-gradient(135deg, #258D58, #764ba2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 15px;
        }

        .metric-card .status {
            padding: 8px 16px;
            border-radius: 25px;
            display: inline-block;
            font-size: 0.85em;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .status.good {
            background: rgba(74, 222, 128, 0.2);
            color: #4ade80;
            border: 1px solid rgba(74, 222, 128, 0.3);
        }

        .status.warning {
            background: rgba(251, 191, 36, 0.2);
            color: #fbbf24;
            border: 1px solid rgba(251, 191, 36, 0.3);
        }

        .status.critical {
            background: rgba(248, 113, 113, 0.2);
            color: #f87171;
            border: 1px solid rgba(248, 113, 113, 0.3);
        }

        .charts-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(550px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .chart-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px);
            padding: 30px;
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.08);
            transition: all 0.3s ease;
        }

        .chart-card:hover {
            border-color: rgba(239, 167, 63, 0.2);
            box-shadow: 0 24px 72px rgba(0, 0, 0, 0.4);
        }

        .chart-card h3 {
            color: #e6e9f0;
            margin-bottom: 25px;
            font-size: 1.4em;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .chart-container {
            position: relative;
            height: 320px;
        }

        .positions-table {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px);
            padding: 30px;
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.08);
            margin-bottom: 30px;
            transition: all 0.3s ease;
        }

        .positions-table:hover {
            border-color: rgba(239, 167, 63, 0.2);
            box-shadow: 0 24px 72px rgba(0, 0, 0, 0.4);
        }

        .positions-table h3 {
            color: #e6e9f0;
            margin-bottom: 25px;
            font-size: 1.4em;
            font-weight: 700;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            padding: 18px;
            text-align: left;
        }

        th {
            background: rgba(255,255,255,0.05);
            color: #94a3b8;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.85em;
            letter-spacing: 0.5px;
        }

        td {
            color: #e2e8f0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        tr:hover td {
            background: rgba(255,255,255,0.02);
        }

        .progress-bar {
            background: rgba(255,255,255,0.1);
            height: 10px;
            border-radius: 5px;
            overflow: hidden;
            margin-top: 8px;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #258D58, #764ba2);
            transition: width 0.5s ease;
            border-radius: 5px;
        }

        .footer {
            text-align: center;
            color: #64748b;
            margin-top: 40px;
            padding: 30px;
            font-size: 0.95em;
        }

        .footer strong {
            color: #94a3b8;
        }

        .icon {
            font-size: 1.2em;
        }

        @media (max-width: 1200px) {
            .charts-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .navbar {
                flex-direction: column;
                gap: 15px;
                text-align: center;
            }

            .navbar-info {
                text-align: center;
            }

            .container {
                padding: 15px;
            }

            .metrics-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="navbar">
        <div class="navbar-brand">
            <div class="logo-container">STAGE</div>
            <div>
                <div class="navbar-title">Hiring Dashboard</div>
                <div class="navbar-subtitle">Powered by Aria AI</div>
            </div>
        </div>
        <div class="navbar-info">
            <a href="/" class="back-btn">← Back to Home</a>
            <div><span class="live-indicator"></span> LIVE</div>
            <div class="last-updated">Updated: <span id="lastUpdated">Loading...</span></div>
        </div>
    </div>

    <div class="container">
        <div class="metrics-grid" id="metricsGrid"></div>

        <div class="charts-grid">
            <div class="chart-card">
                <h3>Hiring Funnel</h3>
                <div class="chart-container">
                    <canvas id="funnelChart"></canvas>
                </div>
            </div>

            <div class="chart-card">
                <h3>Weekly Trend</h3>
                <div class="chart-container">
                    <canvas id="trendChart"></canvas>
                </div>
            </div>
        </div>

        <div class="charts-grid">
            <div class="chart-card">
                <h3>Conversion Rates</h3>
                <div class="chart-container">
                    <canvas id="conversionChart"></canvas>
                </div>
            </div>

            <div class="chart-card">
                <h3>Time to Fill</h3>
                <div class="chart-container">
                    <canvas id="timeToFillChart"></canvas>
                </div>
            </div>
        </div>

        <div class="positions-table">
            <h3>Open Positions</h3>
            <table id="openPositionsTable">
                <thead>
                    <tr>
                        <th>Role</th>
                        <th>Days Open</th>
                        <th>Applicants</th>
                        <th>Pipeline</th>
                        <th>Conversion</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

        <div class="footer">
            Built by <strong>Ankit Saxena</strong> | Senior Talent & People Partner @ STAGE<br>
            Powered by <strong>Aria AI Recruiting Suite</strong>
        </div>
    </div>

    <script>
        // [Same JavaScript code as before - keeping it for brevity]
        let charts = {};

        async function fetchData() {
            try {
                const response = await fetch('/api/dashboard');
                const data = await response.json();
                updateDashboard(data);
            } catch (error) {
                console.error('Error fetching data:', error);
            }
        }

        function updateDashboard(data) {
            updateMetrics(data.metrics);
            updateCharts(data.data, data.metrics);
            updateOpenPositionsTable(data.data.openPositions);

            document.getElementById('lastUpdated').textContent = new Date(data.lastUpdated).toLocaleTimeString();
        }

        function updateMetrics(metrics) {
            const metricsGrid = document.getElementById('metricsGrid');

            const metricCards = [
                { label: 'Open Positions', value: metrics.openRoles, status: metrics.openRoles > 5 ? 'critical' : 'good', statusText: metrics.openRoles > 5 ? 'High Volume' : 'Normal' },
                { label: 'Avg Time to Fill', value: `${metrics.avgTimeToFill}`, suffix: 'days', status: metrics.avgTimeToFill > 45 ? 'warning' : 'good', statusText: metrics.avgTimeToFill > 45 ? 'Slow' : 'Excellent' },
                { label: 'Active Candidates', value: metrics.activeCandidates, status: 'good', statusText: 'In Pipeline' },
                { label: 'Quality Score', value: metrics.qualityScore, suffix: '/100', status: metrics.qualityScore >= 75 ? 'good' : metrics.qualityScore >= 50 ? 'warning' : 'critical', statusText: metrics.qualityScore >= 75 ? 'Excellent' : metrics.qualityScore >= 50 ? 'Good' : 'Needs Work' },
            ];

            metricsGrid.innerHTML = metricCards.map(card => `
                <div class="metric-card">
                    <div class="label">${card.label}</div>
                    <div class="value">${card.value}${card.suffix || ''}</div>
                    <div class="status ${card.status}">${card.statusText}</div>
                </div>
            `).join('');
        }

        function updateCharts(data, metrics) {
            Chart.defaults.color = '#94a3b8';
            Chart.defaults.borderColor = 'rgba(255,255,255,0.1)';

            // Funnel Chart
            const funnelCtx = document.getElementById('funnelChart').getContext('2d');
            if (charts.funnel) charts.funnel.destroy();
            charts.funnel = new Chart(funnelCtx, {
                type: 'bar',
                data: {
                    labels: ['Applications', 'Screened', 'Interviewed', 'Offered', 'Hired'],
                    datasets: [{
                        label: 'Candidates',
                        data: [data.pipeline.totalApplicants, data.pipeline.screened, data.pipeline.interviewed, data.pipeline.offered, data.pipeline.hired],
                        backgroundColor: [
                            'rgba(102, 126, 234, 0.9)',
                            'rgba(118, 75, 162, 0.9)',
                            'rgba(237, 100, 166, 0.9)',
                            'rgba(255, 154, 158, 0.9)',
                            'rgba(74, 222, 128, 0.9)',
                        ],
                        borderRadius: 8,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: 'rgba(255,255,255,0.05)' }
                        },
                        x: {
                            grid: { display: false }
                        }
                    }
                }
            });

            // Weekly Trend Chart
            const trendCtx = document.getElementById('trendChart').getContext('2d');
            if (charts.trend) charts.trend.destroy();
            charts.trend = new Chart(trendCtx, {
                type: 'line',
                data: {
                    labels: data.weeklyMetrics.map(w => w.week),
                    datasets: [
                        {
                            label: 'Applicants',
                            data: data.weeklyMetrics.map(w => w.applicants),
                            borderColor: 'rgba(102, 126, 234, 1)',
                            backgroundColor: 'rgba(102, 126, 234, 0.1)',
                            tension: 0.4,
                            fill: true,
                            borderWidth: 3,
                        },
                        {
                            label: 'Screened',
                            data: data.weeklyMetrics.map(w => w.screened),
                            borderColor: 'rgba(118, 75, 162, 1)',
                            backgroundColor: 'rgba(118, 75, 162, 0.1)',
                            tension: 0.4,
                            fill: true,
                            borderWidth: 3,
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: 'rgba(255,255,255,0.05)' }
                        },
                        x: {
                            grid: { display: false }
                        }
                    }
                }
            });

            // Conversion Rates Chart
            const conversionCtx = document.getElementById('conversionChart').getContext('2d');
            if (charts.conversion) charts.conversion.destroy();
            charts.conversion = new Chart(conversionCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Screening', 'Interview', 'Offer', 'Acceptance'],
                    datasets: [{
                        data: [metrics.screeningRate, metrics.interviewRate, metrics.offerRate, metrics.acceptanceRate],
                        backgroundColor: [
                            'rgba(102, 126, 234, 0.9)',
                            'rgba(118, 75, 162, 0.9)',
                            'rgba(237, 100, 166, 0.9)',
                            'rgba(74, 222, 128, 0.9)',
                        ],
                        borderWidth: 0,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { padding: 20 }
                        }
                    }
                }
            });

            // Time to Fill Chart
            const timeToFillCtx = document.getElementById('timeToFillChart').getContext('2d');
            if (charts.timeToFill) charts.timeToFill.destroy();
            charts.timeToFill = new Chart(timeToFillCtx, {
                type: 'bar',
                data: {
                    labels: data.closedPositions.map(p => p.title),
                    datasets: [{
                        label: 'Days to Fill',
                        data: data.closedPositions.map(p => p.timeToFill),
                        backgroundColor: 'rgba(102, 126, 234, 0.9)',
                        borderRadius: 8,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    indexAxis: 'y',
                    plugins: { legend: { display: false } },
                    scales: {
                        x: {
                            beginAtZero: true,
                            grid: { color: 'rgba(255,255,255,0.05)' }
                        },
                        y: {
                            grid: { display: false }
                        }
                    }
                }
            });
        }

        function updateOpenPositionsTable(positions) {
            const tbody = document.querySelector('#openPositionsTable tbody');

            tbody.innerHTML = positions.map(pos => {
                const conversion = pos.applicants > 0 ? Math.round((pos.offered / pos.applicants) * 100) : 0;
                const daysStatus = pos.daysOpen > 45 ? 'critical' : pos.daysOpen > 30 ? 'warning' : 'good';

                return `
                    <tr>
                        <td>
                            <strong style="color: #e6e9f0; font-size: 1.1em;">${pos.title}</strong><br>
                            <small style="color: #64748b;">${pos.location}</small>
                        </td>
                        <td><span class="status ${daysStatus}">${pos.daysOpen} days</span></td>
                        <td style="font-weight: 600;">${pos.applicants}</td>
                        <td>${pos.screened} → ${pos.interviewed} → ${pos.offered}</td>
                        <td>
                            <strong style="color: #e6e9f0;">${conversion}%</strong>
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: ${conversion}%"></div>
                            </div>
                        </td>
                    </tr>
                `;
            }).join('');
        }

        // Initial load
        fetchData();

        // Auto-refresh every 30 seconds
        setInterval(fetchData, 30000);
    </script>
</body>
</html>
    <style>
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
